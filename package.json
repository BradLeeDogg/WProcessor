{
  "name": "foolscap",
  "version": "0.1.0",
  "description": "Foolscap — a distraction-free, Scrivener-style long-form writing app",
  "author": "Foolscap",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "thesaurus": "node scripts/build-thesaurus.cjs",
    "dev": "npm run thesaurus && electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run thesaurus && electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "package:win": "npm run build && electron-builder --win",
    "package:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@mozilla/readability": "^0.5.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.8.1",
    "docx": "^9.7.1",
    "dompurify": "^3.4.10",
    "jsdom": "^25.0.1",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.8.69"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^3.7.1",
    "@tanstack/react-table": "^8.21.2",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-character-count": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@types/archiver": "^6.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.4.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.7",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "wordnet-db": "^3.1.14",
    "zustand": "^5.0.3"
  }
}
